<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<!-- Empty launch screen dict: without this iOS letterboxes the app and the
	     WKWebView won't be full-size (screenshot would look wrong). -->
	<key>UILaunchScreen</key>
	<dict/>
	<!-- 全屏沉浸(AR 眼镜):启动起即隐藏状态栏;运行时由 VC prefersStatusBarHidden 维持。
	     UIViewControllerBasedStatusBarAppearance 保持默认 YES,VC override 才生效。 -->
	<key>UIStatusBarHidden</key>
	<true/>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<!-- POC M2 hits 127.0.0.1 over raw SSH (not HTTP); ATS does not gate raw
	     sockets, but declare local-networking intent for clarity. -->
	<key>NSLocalNetworkUsageDescription</key>
	<string>Connect to a local throwaway SSH server for terminal POC.</string>
	<!-- SPEC §8 real-device config-injection channel: a self-contained `.xrhosts`
	     bundle (Valet output) AirDropped to the phone → "用 XrealPOC 打开" → import.
	     We OWN the type (UTExportedTypeDeclarations) and claim Owner rank so AirDrop
	     offers us. We do NOT list public.json in LSItemContentTypes (would noisily
	     grab every .json); the type conforms to public.data/public.json only so the
	     bundle is recognized as JSON-shaped, which does not make us a .json handler. -->
	<key>CFBundleDocumentTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeName</key>
			<string>XREAL Host Config</string>
			<key>LSHandlerRank</key>
			<string>Owner</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>io.github.kevinfitzroy.xrealclient.hosts</string>
			</array>
		</dict>
	</array>
	<key>UTExportedTypeDeclarations</key>
	<array>
		<dict>
			<key>UTTypeIdentifier</key>
			<string>io.github.kevinfitzroy.xrealclient.hosts</string>
			<key>UTTypeDescription</key>
			<string>XREAL Host Config</string>
			<key>UTTypeConformsTo</key>
			<array>
				<string>public.json</string>
				<string>public.data</string>
			</array>
			<key>UTTypeTagSpecification</key>
			<dict>
				<key>public.filename-extension</key>
				<array>
					<string>xrhosts</string>
				</array>
			</dict>
		</dict>
	</array>
</dict>
</plist>
