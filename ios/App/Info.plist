<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- 录音 Live Activity(锁屏/灵动岛状态)。前台录音可用;息屏/切后台不再续录(见下)。 -->
	<key>NSSupportsLiveActivities</key>
	<true/>
	<!-- ⚠️ 不要加 UIBackgroundModes:audio。曾用于「#23 锁屏录音息屏续录」,但 App Store 审核
	     Guideline 2.5.4(2026-06-15,build 22)以「声明 audio 后台但无后台播放内容」拒。后台
	     录音虽是合法用途,但需回信+真机录屏证明;首提取舍后改为仅前台录音。若日后要恢复息屏续录,
	     重加此键并按 2.5.4 Next Steps 提交录屏(详见 issue #30)。 -->
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundleDisplayName</key>
	<string>Agent Station</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>AgentStationGitRevision</key>
	<string>unknown</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<!-- Empty launch screen dict: without this iOS letterboxes the app and the
	     WKWebView won't be full-size (screenshot would look wrong). -->
	<key>UILaunchScreen</key>
	<dict/>
	<!-- 全屏沉浸(AR 眼镜):启动起即隐藏状态栏;运行时由 VC prefersStatusBarHidden 维持。
	     UIViewControllerBasedStatusBarAppearance 保持默认 YES,VC override 才生效。 -->
	<key>UIStatusBarHidden</key>
	<true/>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<!-- POC M2 hits 127.0.0.1 over raw SSH (not HTTP); ATS does not gate raw
	     sockets, but declare local-networking intent for clarity. -->
	<key>NSLocalNetworkUsageDescription</key>
	<string>Connect to a local throwaway SSH server for terminal POC.</string>
	<!-- 语音输入(SPEC §4/§7):按住语音键录音 → 豆包流式 ASR → 注入 SSH 终端。
	     首次按语音键时运行时请求(requestRecordPermission)。 -->
	<key>NSMicrophoneUsageDescription</key>
	<string>按住语音键说话,把语音识别成文本注入远程终端。</string>
	<!-- SPEC §8 real-device config-injection channel: a self-contained `.xrhosts`
	     bundle (Valet output) AirDropped to the phone → "用 Agent Station 打开" → import.
	     We OWN the type (UTExportedTypeDeclarations) and claim Owner rank so AirDrop
	     offers us. We do NOT list public.json in LSItemContentTypes (would noisily
	     grab every .json); the type conforms to public.data/public.json only so the
	     bundle is recognized as JSON-shaped, which does not make us a .json handler. -->
	<key>CFBundleDocumentTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeName</key>
			<string>Agent Station Config</string>
			<key>LSHandlerRank</key>
			<string>Owner</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>io.github.kevinfitzroy.xrealclient.hosts</string>
			</array>
		</dict>
	</array>
	<key>UTExportedTypeDeclarations</key>
	<array>
		<dict>
			<key>UTTypeIdentifier</key>
			<string>io.github.kevinfitzroy.xrealclient.hosts</string>
			<key>UTTypeDescription</key>
			<string>Agent Station Config</string>
			<key>UTTypeConformsTo</key>
			<array>
				<string>public.json</string>
				<string>public.data</string>
			</array>
			<key>UTTypeTagSpecification</key>
			<dict>
				<key>public.filename-extension</key>
				<array>
					<string>xrhosts</string>
				</array>
			</dict>
		</dict>
	</array>
</dict>
</plist>
